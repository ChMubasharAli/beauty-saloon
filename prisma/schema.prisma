generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id    String  @id @default(cuid())
  email String  @unique
  name  String?
  posts Post[]
}

model Post {
  id        String  @id @default(cuid())
  title     String
  content   String? @db.Text
  published Boolean @default(false)
  atuhor    User    @relation(fields: [authorId], references: [id])
  authorId  String
}


